{
  "name": "@zh-npm/claude-authenticity-detector",
  "version": "0.1.0",
  "description": "Validate whether an API relay/proxy is serving authentic Claude models",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Z-M-Huang/claude-authenticity-detector.git"
  },
  "homepage": "https://github.com/Z-M-Huang/claude-authenticity-detector#readme",
  "bugs": {
    "url": "https://github.com/Z-M-Huang/claude-authenticity-detector/issues"
  },
  "author": "Z-M-Huang",
  "keywords": [
    "claude",
    "anthropic",
    "authenticity",
    "detector",
    "relay",
    "proxy",
    "verification",
    "streaming",
    "sse",
    "ai",
    "llm"
  ],
  "bin": {
    "claude-authenticity-detector": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@vitest/coverage-v8": "^3.1.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0"
}
